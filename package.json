        "@tarojs/plugin-framework-react": "3.6.0",
        "@tarojs/plugin-html": "3.6.0",
        "@tarojs/plugin-platform-alipay": "3.6.0",
        "@tarojs/plugin-platform-swan": "3.6.0",

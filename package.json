        "@types/webpack-env": "^1.13.6",
        "babel-preset-taro": "3.6.0",
        "eslint": "^7.12.0",
        "eslint-config-taro": "3.6.0",
        "eslint-plugin-react": "^7.12.0",
        "postcss": "^8.4.18",
        "typescript": "^4.0.0",
        "webpack": "5.91.0"

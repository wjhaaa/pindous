.detail{background-color:#f8f9fa;min-height:100vh}.loading{align-items:center;color:#666;display:flex;font-size:28rpx;height:100vh;justify-content:center}.work-image-section{background:#fff;padding:30rpx;text-align:center}.work-image-section .work-image{border-radius:10rpx;height:400rpx;width:100%}.work-info{background:#fff;margin:20rpx 0;padding:30rpx}.work-info .work-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:20rpx}.work-info .work-header .work-title{color:#333;flex:1;font-size:32rpx;font-weight:700;margin-right:20rpx}.work-info .work-header .like-section{align-items:center;background:#f5f5f5;border-radius:20rpx;display:flex;padding:10rpx 15rpx}.work-info .work-header .like-section .like-count{color:#666;font-size:24rpx;margin-left:8rpx}.work-info .work-meta{align-items:center;display:flex;margin-bottom:20rpx}.work-info .work-meta .work-category{background:#f0f2f5;border-radius:15rpx;color:#666;font-size:24rpx;margin-left:15rpx;padding:5rpx 15rpx}.work-info .work-description{color:#333;font-size:26rpx;line-height:1.6;margin-bottom:20rpx}.work-info .work-tags{margin-bottom:25rpx}.work-info .work-tags .tag{margin-bottom:10rpx;margin-right:10rpx}.work-info .work-stats{background:#f8f9fa;border-radius:10rpx;display:flex;justify-content:space-between;padding:20rpx}.work-info .work-stats .stat-item{text-align:center}.work-info .work-stats .stat-item .stat-label{color:#999;display:block;font-size:20rpx;margin-bottom:5rpx}.work-info .work-stats .stat-item .stat-value{color:#333;display:block;font-size:22rpx;font-weight:700}.materials-section,.steps-section{background:#fff;margin:20rpx 0;padding:30rpx}.materials-section .section-title,.steps-section .section-title{border-bottom:2rpx solid #f0f2f5;color:#333;font-size:28rpx;font-weight:700;margin-bottom:20rpx;padding-bottom:10rpx}.materials-list .material-item{align-items:center;border-bottom:1rpx solid #f0f2f5;display:flex;padding:15rpx 0}.materials-list .material-item:last-child{border-bottom:none}.materials-list .material-item .material-text{color:#333;font-size:24rpx;margin-left:15rpx}.steps-list .step-item{align-items:flex-start;border-bottom:1rpx solid #f0f2f5;display:flex;padding:20rpx 0}.steps-list .step-item:last-child{border-bottom:none}.steps-list .step-item .step-number{align-items:center;background:#1890ff;border-radius:50%;color:#fff;display:flex;flex-shrink:0;font-size:20rpx;font-weight:700;height:40rpx;justify-content:center;margin-right:20rpx;width:40rpx}.steps-list .step-item .step-text{color:#333;flex:1;font-size:24rpx;line-height:1.5}.action-buttons{background:#fff;display:flex;gap:20rpx;margin:20rpx 0;padding:30rpx}.action-buttons .action-btn{flex:1}@media (max-width:750rpx){.work-image-section{padding:20rpx}.work-image-section .work-image{height:300rpx}.work-info{padding:20rpx}.work-info .work-header .work-title{font-size:28rpx}.work-info .work-description{font-size:22rpx}.work-info .work-stats{flex-direction:column;gap:15rpx}.work-info .work-stats .stat-item{display:flex;justify-content:space-between;text-align:left}.materials-section,.steps-section{padding:20rpx}.action-buttons{flex-direction:column;padding:20rpx}}
.quiz-home{background:linear-gradient(135deg,#f5f7fa,#e8eef5);min-height:100vh;padding-bottom:40px}.header{padding:40px 20px 30px}.header .header-content{color:#2c3e50;text-align:center}.header .header-content .header-title{color:#5b86e5;display:block;font-size:32px;font-weight:700;letter-spacing:.5px;margin-bottom:8px}.header .header-content .header-subtitle{color:#606266;font-size:14px;font-weight:500;opacity:.8}.stats-section{padding:0 20px 30px}.stats-section .stats-card{align-items:center;backdrop-filter:blur(10px);background:hsla(0,0%,100%,.9);border:1px solid rgba(91,134,229,.1);border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,.04);display:flex;justify-content:space-around;padding:20px}.stats-section .stats-card .stat-item{flex:1;text-align:center}.stats-section .stats-card .stat-item .stat-value{color:#5b86e5;display:block;font-size:28px;font-weight:700;margin-bottom:6px}.stats-section .stats-card .stat-item .stat-label{color:#909399;font-size:12px;font-weight:500}.stats-section .stats-card .stat-divider{background:#dcdfe6;height:32px;width:1px}.daily-section{padding:0 20px 30px}.daily-section .section-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:16px}.daily-section .section-header .section-title{color:#2c3e50;font-size:18px;font-weight:600}.daily-section .section-header .daily-badge{background:rgba(91,134,229,.1);border-radius:12px;padding:4px 12px}.daily-section .section-header .daily-badge .badge-text{color:#5b86e5;font-size:11px;font-weight:600}.daily-section .daily-card{background:#fff;border:1px solid #ebeef5;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.04);cursor:pointer;padding:18px;transition:all .3s ease}.daily-section .daily-card:active{box-shadow:0 4px 12px rgba(0,0,0,.08);transform:scale(.98)}.daily-section .daily-card .daily-content{align-items:center;display:flex;gap:14px}.daily-section .daily-card .daily-content .daily-icon{font-size:40px}.daily-section .daily-card .daily-content .daily-info{flex:1}.daily-section .daily-card .daily-content .daily-info .daily-title{color:#2c3e50;display:block;font-size:15px;font-weight:600;line-height:1.5;margin-bottom:10px}.daily-section .daily-card .daily-content .daily-info .daily-meta{align-items:center;display:flex;justify-content:space-between}.daily-section .daily-card .daily-content .daily-info .daily-meta .difficulty-tag{border-radius:10px;padding:3px 10px}.daily-section .daily-card .daily-content .daily-info .daily-meta .difficulty-tag .difficulty-text{color:#fff;font-size:11px;font-weight:600}.daily-section .daily-card .daily-content .daily-info .daily-meta .daily-action{color:#5b86e5;font-size:13px;font-weight:600}.categories-section{padding:0 20px 30px}.categories-section .section-header{margin-bottom:16px}.categories-section .section-header .section-title{color:#2c3e50;font-size:18px;font-weight:600}.categories-section .categories-grid{display:grid;gap:10px;grid-template-columns:repeat(2,1fr)}.categories-section .categories-grid .category-card{background:#fff;border:1px solid #ebeef5;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.04);cursor:pointer;overflow:hidden;padding:18px;position:relative;text-align:center;transition:all .3s ease}.categories-section .categories-grid .category-card:active{box-shadow:0 4px 12px rgba(0,0,0,.08);transform:scale(.95)}.categories-section .categories-grid .category-card .category-icon{border-radius:12px;display:block;font-size:32px;height:56px;line-height:56px;margin-bottom:8px;margin-left:auto;margin-right:auto;width:56px}.categories-section .categories-grid .category-card .category-name{color:#2c3e50;display:block;font-size:14px;font-weight:600;margin-bottom:4px}.categories-section .categories-grid .category-card .category-count{color:#909399;font-size:11px;font-weight:500}
.quiz-home{background:linear-gradient(135deg,#667eea,#764ba2);min-height:100vh;padding-bottom:40px}.header{padding:40px 20px 30px}.header .header-content{color:#fff;text-align:center}.header .header-content .header-title{display:block;font-size:36px;font-weight:800;letter-spacing:1px;margin-bottom:8px}.header .header-content .header-subtitle{font-size:16px;font-weight:500;opacity:.9}.stats-section{padding:0 20px 30px}.stats-section .stats-card{align-items:center;backdrop-filter:blur(10px);background:hsla(0,0%,100%,.15);border:1px solid hsla(0,0%,100%,.2);border-radius:20px;box-shadow:0 8px 32px rgba(0,0,0,.1);display:flex;justify-content:space-around;padding:24px}.stats-section .stats-card .stat-item{flex:1;text-align:center}.stats-section .stats-card .stat-item .stat-value{color:#fff;display:block;font-size:32px;font-weight:800;margin-bottom:6px}.stats-section .stats-card .stat-item .stat-label{color:hsla(0,0%,100%,.9);font-size:13px;font-weight:500}.stats-section .stats-card .stat-divider{background:hsla(0,0%,100%,.3);height:40px;width:1px}.daily-section{padding:0 20px 30px}.daily-section .section-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:16px}.daily-section .section-header .section-title{color:#fff;font-size:20px;font-weight:700}.daily-section .section-header .daily-badge{background:hsla(0,0%,100%,.2);border-radius:20px;padding:6px 14px}.daily-section .section-header .daily-badge .badge-text{color:#fff;font-size:12px;font-weight:600}.daily-section .daily-card{background:#fff;border-radius:16px;box-shadow:0 10px 40px rgba(0,0,0,.1);cursor:pointer;padding:20px;transition:all .3s ease}.daily-section .daily-card:active{transform:scale(.98)}.daily-section .daily-card .daily-content{align-items:center;display:flex;gap:16px}.daily-section .daily-card .daily-content .daily-icon{font-size:48px}.daily-section .daily-card .daily-content .daily-info{flex:1}.daily-section .daily-card .daily-content .daily-info .daily-title{color:#1f2937;display:block;font-size:16px;font-weight:600;line-height:1.5;margin-bottom:12px}.daily-section .daily-card .daily-content .daily-info .daily-meta{align-items:center;display:flex;justify-content:space-between}.daily-section .daily-card .daily-content .daily-info .daily-meta .difficulty-tag{border-radius:12px;padding:4px 12px}.daily-section .daily-card .daily-content .daily-info .daily-meta .difficulty-tag .difficulty-text{color:#fff;font-size:12px;font-weight:600}.daily-section .daily-card .daily-content .daily-info .daily-meta .daily-action{color:#667eea;font-size:14px;font-weight:600}.categories-section{padding:0 20px 30px}.categories-section .section-header{margin-bottom:16px}.categories-section .section-header .section-title{color:#fff;font-size:20px;font-weight:700}.categories-section .categories-grid{display:grid;gap:12px;grid-template-columns:repeat(2,1fr)}.categories-section .categories-grid .category-card{background:hsla(0,0%,100%,.95);border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);cursor:pointer;padding:20px;text-align:center;transition:all .3s ease}.categories-section .categories-grid .category-card:active{transform:scale(.95)}.categories-section .categories-grid .category-card .category-icon{display:block;font-size:32px;margin-bottom:8px}.categories-section .categories-grid .category-card .category-name{color:#1f2937;display:block;font-size:15px;font-weight:700;margin-bottom:4px}.categories-section .categories-grid .category-card .category-count{color:#6b7280;font-size:12px;font-weight:500}
.generatorPage{background:#f5f7fa;min-height:100vh}.container{margin:0 auto;max-width:720rpx;padding:18rpx 16rpx 40rpx;width:100%}.hero{padding:6rpx 2rpx 14rpx}.heroTitle{color:rgba(0,0,0,.88);font-size:34rpx;font-weight:700;text-align:left}.heroSub{color:rgba(0,0,0,.56);font-size:20rpx;line-height:1.5;margin-top:6rpx;text-align:left}.panel{background:#fff;border:1rpx solid rgba(0,0,0,.08);border-radius:18rpx;box-shadow:0 10rpx 26rpx rgba(0,0,0,.04);margin-bottom:14rpx;padding:16rpx}.panelTitleRow{display:flex;flex-direction:column;gap:6rpx;margin-bottom:12rpx}.panelTitle{color:rgba(0,0,0,.88);font-size:24rpx;font-weight:700}.panelSubTitle{color:rgba(0,0,0,.4);font-size:18rpx}.uploadBox{background:rgba(0,0,0,.02);border:2rpx dashed rgba(0,0,0,.14);border-radius:16rpx;padding:18rpx 14rpx;text-align:center}.uploadMainText{color:rgba(0,0,0,.88);font-size:22rpx;font-weight:800}.uploadHelpText{color:rgba(0,0,0,.4);font-size:18rpx;margin-top:6rpx}.previewImg{background:#fff;border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;height:220rpx;overflow:hidden;width:100%}.smallMuted{color:rgba(0,0,0,.4);font-size:18rpx}.rowBetween{align-items:center;display:flex;gap:10rpx;justify-content:space-between}.sizeValueRow{align-items:baseline;display:flex;gap:8rpx;margin-bottom:6rpx}.sizeValue{color:rgba(0,0,0,.88);font-size:40rpx;font-weight:800}.sizeUnit{color:rgba(0,0,0,.56);font-size:22rpx;font-weight:700}.sizeMeta{color:rgba(0,0,0,.4);font-size:18rpx;margin-left:auto}.pillRow{display:flex;flex-wrap:wrap;gap:10rpx;margin-top:10rpx}.pill{background:rgba(0,0,0,.04);border:1rpx solid rgba(0,0,0,.06);border-radius:999rpx;color:rgba(0,0,0,.7);font-size:20rpx;font-weight:700;padding:8rpx 14rpx}.pillActive{background:rgba(59,130,246,.12);border:1rpx solid rgba(59,130,246,.18);color:rgba(37,99,235,.92)}.label{color:rgba(0,0,0,.88);font-size:22rpx;font-weight:700}.toggleBox{border-radius:999rpx;height:24rpx;position:relative;transition:all .2s ease;width:42rpx}.toggleDot{background:#fff;border-radius:999rpx;box-shadow:0 4rpx 10rpx rgba(0,0,0,.12);height:20rpx;left:0;position:absolute;top:2rpx;transition:all .2s ease;width:20rpx}.primaryBtn{background-image:linear-gradient(135deg,#3b82f6,#2563eb)!important;border:none!important;border-radius:999rpx!important;box-shadow:0 12rpx 26rpx rgba(37,99,235,.2);height:44rpx!important;line-height:44rpx!important}.ghostBtn{background:rgba(59,130,246,.06)!important;border:1rpx solid rgba(59,130,246,.22)!important;border-radius:999rpx!important;color:rgba(37,99,235,.92)!important;height:40rpx!important;line-height:40rpx!important}.canvasBox{background:#fff;border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;overflow:hidden}.statsList{display:grid;gap:10rpx;grid-template-columns:1fr 1fr}.statItem{align-items:center;background:#fff;border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;display:flex;justify-content:space-between;padding:12rpx}.statLeft{align-items:center;display:flex;gap:10rpx}.swatch{border:1rpx solid rgba(0,0,0,.1);border-radius:6rpx;height:18rpx;width:18rpx}.codeText{color:rgba(0,0,0,.88);font-size:20rpx;font-weight:700}.countText{color:rgba(0,0,0,.56);font-size:20rpx;font-weight:700}.successCard{background:rgba(34,197,94,.06);border:1rpx solid rgba(34,197,94,.18);border-radius:16rpx;padding:12rpx 14rpx}.successTitle{color:rgba(0,0,0,.82);font-size:20rpx;font-weight:800}.successDesc{color:rgba(0,0,0,.52);font-size:18rpx;margin-top:4rpx}@media (max-width:390rpx){.statsList{grid-template-columns:1fr}}
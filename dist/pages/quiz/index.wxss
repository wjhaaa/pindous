.quiz{background:linear-gradient(135deg,#f5f7fa,#e8eef5);min-height:100vh;padding-bottom:40px}.quiz-loading{align-items:center;background:linear-gradient(135deg,#f5f7fa,#e8eef5);display:flex;height:100vh;justify-content:center}.quiz-loading .loading-text{color:#606266;font-size:14px}.quiz-container{padding:16px}.quiz-header{margin-bottom:16px}.quiz-header .header-content{backdrop-filter:blur(10px);background:hsla(0,0%,100%,.9);border:1px solid rgba(91,134,229,.1);border-radius:12px;padding:16px}.quiz-header .progress-info .progress-text{color:#2c3e50;display:block;font-size:14px;font-weight:600;margin-bottom:10px}.quiz-header .progress-info .progress-bar{background:#ebeef5;border-radius:3px;height:6px;overflow:hidden}.quiz-header .progress-info .progress-bar .progress-fill{background:linear-gradient(90deg,#5b86e5,#36d1dc);border-radius:3px;height:100%;transition:width .3s ease}.question-card{animation:slideUp .3s ease;background:#fff;border:1px solid #ebeef5;border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,.04);padding:20px}@keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}.question-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:16px}.question-header .question-meta{align-items:center;display:flex;gap:8px}.question-header .question-meta .difficulty-badge{border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,.08);padding:4px 12px}.question-header .question-meta .difficulty-badge .difficulty-text{color:#fff;font-size:11px;font-weight:600}.question-header .question-meta .category-badge{background:#f5f7fa;border-radius:12px;color:#606266;font-size:11px;font-weight:600;padding:4px 12px}.question-header .question-meta .learned-badge{background:#f0f9ff;border:1px solid rgba(91,134,229,.2);border-radius:12px;color:#5b86e5;font-size:11px;font-weight:600;padding:4px 12px}.question-header .favorite-btn{align-items:center;background:#f5f7fa;border-radius:50%;cursor:pointer;display:flex;height:36px;justify-content:center;transition:all .3s ease;width:36px}.question-header .favorite-btn.active{background:#fef0f0;transform:scale(1.05)}.question-header .favorite-btn .favorite-icon{font-size:18px}.question-content{margin-bottom:20px}.question-content .question-title{color:#2c3e50;display:block;font-size:16px;font-weight:600;line-height:1.6}.answer-toggle{align-items:center;background:linear-gradient(135deg,#5b86e5,#36d1dc);border-radius:10px;box-shadow:0 2px 8px rgba(91,134,229,.2);cursor:pointer;display:flex;gap:6px;justify-content:center;margin-bottom:16px;padding:14px;transition:all .3s ease}.answer-toggle:active{transform:scale(.98)}.answer-toggle .toggle-text{color:#fff;font-size:14px;font-weight:600}.answer-toggle .toggle-icon{color:#fff;font-size:10px;transition:transform .3s ease}.answer-section{animation:fadeIn .3s ease;margin-bottom:20px}@keyframes fadeIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}.answer-card{background:#f0f9ff;border:1px solid #5b86e5;border-radius:10px;margin-bottom:12px;padding:16px}.answer-card .answer-header{display:flex;flex-direction:column;gap:6px}.answer-card .answer-header .answer-label{color:#5b86e5;font-size:12px;font-weight:600;letter-spacing:.5px;text-transform:uppercase}.answer-card .answer-header .answer-value{color:#2c3e50;font-size:15px;font-weight:700;line-height:1.5}.explanation-card{background:#fef9e7;border:1px solid #e6a23c;border-radius:10px;padding:16px}.explanation-card .explanation-header{margin-bottom:10px}.explanation-card .explanation-header .explanation-label{color:#e6a23c;font-size:12px;font-weight:600;letter-spacing:.5px;text-transform:uppercase}.explanation-card .explanation-text{color:#606266;font-size:13px;line-height:1.6}.action-buttons{display:flex;gap:10px}.action-buttons .action-btn{align-items:center;border-radius:10px;cursor:pointer;display:flex;flex:1;justify-content:center;padding:14px;transition:all .3s ease}.action-buttons .action-btn.secondary{background:#f5f7fa;border:1px solid #dcdfe6}.action-buttons .action-btn.secondary:active{background:#ebeef5;transform:scale(.98)}.action-buttons .action-btn.secondary .btn-text{color:#606266;font-size:14px;font-weight:600}.action-buttons .action-btn.primary{background:linear-gradient(135deg,#5b86e5,#36d1dc);box-shadow:0 2px 8px rgba(91,134,229,.2)}.action-buttons .action-btn.primary:active{transform:scale(.98)}.action-buttons .action-btn.primary .btn-text{color:#fff;font-size:14px;font-weight:600}
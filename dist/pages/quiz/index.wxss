.quiz{background:linear-gradient(135deg,#667eea,#764ba2);min-height:100vh;padding-bottom:40px}.quiz-loading{align-items:center;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;height:100vh;justify-content:center}.quiz-loading .loading-text{color:#fff;font-size:16px}.quiz-container{padding:20px}.quiz-header{margin-bottom:20px}.quiz-header .header-content{backdrop-filter:blur(10px);background:hsla(0,0%,100%,.15);border:1px solid hsla(0,0%,100%,.2);border-radius:16px;padding:20px}.quiz-header .progress-info .progress-text{color:#fff;display:block;font-size:16px;font-weight:600;margin-bottom:12px}.quiz-header .progress-info .progress-bar{background:hsla(0,0%,100%,.3);border-radius:4px;height:8px;overflow:hidden}.quiz-header .progress-info .progress-bar .progress-fill{background:linear-gradient(90deg,#fff,hsla(0,0%,100%,.8));border-radius:4px;box-shadow:0 2px 8px hsla(0,0%,100%,.3);height:100%;transition:width .3s ease}.question-card{animation:slideUp .3s ease;background:#fff;border-radius:20px;box-shadow:0 10px 40px rgba(0,0,0,.1);padding:24px}@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}.question-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:20px}.question-header .question-meta{align-items:center;display:flex;gap:12px}.question-header .question-meta .difficulty-badge{border-radius:20px;box-shadow:0 2px 8px rgba(0,0,0,.1);padding:6px 14px}.question-header .question-meta .difficulty-badge .difficulty-text{color:#fff;font-size:12px;font-weight:600}.question-header .question-meta .category-badge{background:#f3f4f6;border-radius:20px;color:#6b7280;font-size:12px;font-weight:600;padding:6px 14px}.question-header .question-meta .learned-badge{background:#ecfdf5;border:1px solid #10b981;border-radius:20px;color:#10b981;font-size:12px;font-weight:600;padding:6px 14px}.question-header .favorite-btn{align-items:center;background:#f9fafb;border-radius:50%;cursor:pointer;display:flex;height:44px;justify-content:center;transition:all .3s ease;width:44px}.question-header .favorite-btn.active{background:#fef2f2;transform:scale(1.1)}.question-header .favorite-btn .favorite-icon{font-size:20px}.question-content{margin-bottom:24px}.question-content .question-title{color:#1f2937;display:block;font-size:18px;font-weight:700;line-height:1.6}.answer-toggle{align-items:center;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:12px;box-shadow:0 4px 12px rgba(102,126,234,.3);cursor:pointer;display:flex;gap:8px;justify-content:center;margin-bottom:20px;padding:16px;transition:all .3s ease}.answer-toggle:active{transform:scale(.98)}.answer-toggle .toggle-text{color:#fff;font-size:15px;font-weight:600}.answer-toggle .toggle-icon{color:#fff;font-size:12px;transition:transform .3s ease}.answer-section{animation:fadeIn .3s ease;margin-bottom:24px}@keyframes fadeIn{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}.answer-card{background:#ecfdf5;border:2px solid #10b981;border-radius:12px;margin-bottom:16px;padding:20px}.answer-card .answer-header{display:flex;flex-direction:column;gap:8px}.answer-card .answer-header .answer-label{color:#059669;font-size:13px;font-weight:600;letter-spacing:.5px;text-transform:uppercase}.answer-card .answer-header .answer-value{color:#047857;font-size:16px;font-weight:700;line-height:1.5}.explanation-card{background:#fef3c7;border:2px solid #f59e0b;border-radius:12px;padding:20px}.explanation-card .explanation-header{margin-bottom:12px}.explanation-card .explanation-header .explanation-label{color:#d97706;font-size:13px;font-weight:600;letter-spacing:.5px;text-transform:uppercase}.explanation-card .explanation-text{color:#92400e;font-size:14px;line-height:1.6}.action-buttons{display:flex;gap:12px}.action-buttons .action-btn{align-items:center;border-radius:12px;cursor:pointer;display:flex;flex:1;justify-content:center;padding:16px;transition:all .3s ease}.action-buttons .action-btn.secondary{background:#f9fafb;border:2px solid #e5e7eb}.action-buttons .action-btn.secondary:active{background:#f3f4f6;transform:scale(.98)}.action-buttons .action-btn.secondary .btn-text{color:#6b7280;font-size:15px;font-weight:600}.action-buttons .action-btn.primary{background:linear-gradient(135deg,#667eea,#764ba2);box-shadow:0 4px 12px rgba(102,126,234,.3)}.action-buttons .action-btn.primary:active{transform:scale(.98)}.action-buttons .action-btn.primary .btn-text{color:#fff;font-size:15px;font-weight:600}
.quiz-flagged{background:linear-gradient(135deg,#ef4444,#dc2626);min-height:100vh;padding-bottom:40px}.header{padding:40px 20px 30px}.header .header-content{color:#fff;text-align:center}.header .header-content .header-title{display:block;font-size:32px;font-weight:800;letter-spacing:1px;margin-bottom:8px}.header .header-content .header-subtitle{font-size:16px;font-weight:500;opacity:.9}.empty-section{padding:80px 20px 60px;text-align:center}.empty-section .empty-icon{font-size:80px;margin-bottom:20px}.empty-section .empty-text{color:#fff;display:block;font-size:20px;font-weight:700;margin-bottom:8px}.empty-section .empty-desc{color:hsla(0,0%,100%,.8);display:block;font-size:14px;line-height:1.6;margin-bottom:40px;padding:0 40px}.empty-section .empty-actions .action-btn{align-items:center;border-radius:12px;cursor:pointer;display:inline-flex;justify-content:center;padding:16px 32px;transition:all .3s ease}.empty-section .empty-actions .action-btn.primary{background:#fff;box-shadow:0 4px 12px rgba(0,0,0,.2)}.empty-section .empty-actions .action-btn.primary:active{transform:scale(.98)}.empty-section .empty-actions .action-btn.primary .btn-text{color:#ef4444;font-size:15px;font-weight:700}.flagged-list{padding:0 20px}.flagged-list .flagged-item{background:#fff;border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);cursor:pointer;margin-bottom:16px;padding:20px;transition:all .3s ease}.flagged-list .flagged-item:active{transform:scale(.98)}.flagged-list .flagged-item .flagged-header{align-items:center;display:flex;margin-bottom:16px}.flagged-list .flagged-item .flagged-header .difficulty-badge{border-radius:12px;margin-right:10px;padding:4px 12px}.flagged-list .flagged-item .flagged-header .difficulty-badge .difficulty-text{color:#fff;font-size:12px;font-weight:600}.flagged-list .flagged-item .flagged-header .category-badge{background:#f3f4f6;border-radius:12px;color:#6b7280;flex:1;font-size:12px;font-weight:600;padding:4px 12px}.flagged-list .flagged-item .flagged-header .flagged-icon{font-size:20px}.flagged-list .flagged-item .flagged-title{color:#1f2937;display:block;font-size:16px;font-weight:600;line-height:1.6;margin-bottom:12px}.flagged-list .flagged-item .flagged-tags{display:flex;flex-wrap:wrap;gap:8px}.flagged-list .flagged-item .flagged-tags .tag{background:#fef2f2;border-radius:6px;padding:4px 10px}.flagged-list .flagged-item .flagged-tags .tag .tag-text{color:#dc2626;font-size:12px;font-weight:500}
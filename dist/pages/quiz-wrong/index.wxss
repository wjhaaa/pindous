.quiz-wrong{background:linear-gradient(135deg,#ef4444,#dc2626);min-height:100vh;padding-bottom:40px}.header{padding:40px 20px 30px}.header .header-content{color:#fff;text-align:center}.header .header-content .header-title{display:block;font-size:32px;font-weight:800;letter-spacing:1px;margin-bottom:8px}.header .header-content .header-subtitle{font-size:16px;font-weight:500;opacity:.9}.empty-section{padding:80px 20px 60px;text-align:center}.empty-section .empty-icon{font-size:80px;margin-bottom:20px}.empty-section .empty-text{color:#fff;display:block;font-size:20px;font-weight:700;margin-bottom:8px}.empty-section .empty-desc{color:hsla(0,0%,100%,.8);display:block;font-size:14px;margin-bottom:40px}.empty-section .empty-actions .action-btn{align-items:center;border-radius:12px;cursor:pointer;display:inline-flex;justify-content:center;padding:16px 32px;transition:all .3s ease}.empty-section .empty-actions .action-btn.primary{background:#fff;box-shadow:0 4px 12px rgba(0,0,0,.2)}.empty-section .empty-actions .action-btn.primary:active{transform:scale(.98)}.empty-section .empty-actions .action-btn.primary .btn-text{color:#ef4444;font-size:15px;font-weight:700}.wrong-list{padding:0 20px}.wrong-list .wrong-item{background:#fff;border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);cursor:pointer;margin-bottom:16px;padding:20px;transition:all .3s ease}.wrong-list .wrong-item:active{transform:scale(.98)}.wrong-list .wrong-item .wrong-header{align-items:center;display:flex;margin-bottom:16px}.wrong-list .wrong-item .wrong-header .difficulty-badge{border-radius:12px;margin-right:10px;padding:4px 12px}.wrong-list .wrong-item .wrong-header .difficulty-badge .difficulty-text{color:#fff;font-size:12px;font-weight:600}.wrong-list .wrong-item .wrong-header .category-badge{background:#f3f4f6;border-radius:12px;color:#6b7280;flex:1;font-size:12px;font-weight:600;padding:4px 12px}.wrong-list .wrong-item .wrong-header .wrong-icon{font-size:20px}.wrong-list .wrong-item .wrong-title{color:#1f2937;display:block;font-size:16px;font-weight:600;line-height:1.6;margin-bottom:12px}.wrong-list .wrong-item .wrong-tags{display:flex;flex-wrap:wrap;gap:8px}.wrong-list .wrong-item .wrong-tags .tag{background:#fef2f2;border-radius:6px;padding:4px 10px}.wrong-list .wrong-item .wrong-tags .tag .tag-text{color:#dc2626;font-size:12px;font-weight:500}.footer-actions{padding:20px}.footer-actions .clear-btn{backdrop-filter:blur(10px);background:hsla(0,0%,100%,.2);border:1px solid hsla(0,0%,100%,.3);border-radius:12px;cursor:pointer;padding:16px;text-align:center;transition:all .3s ease}.footer-actions .clear-btn:active{background:hsla(0,0%,100%,.3);transform:scale(.98)}.footer-actions .clear-btn .clear-text{color:#fff;font-size:15px;font-weight:600}
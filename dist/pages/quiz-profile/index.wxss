.quiz-profile{background:linear-gradient(135deg,#f5f7fa,#e8eef5);min-height:100vh;padding-bottom:40px}.header{padding:40px 20px 30px}.header .header-content{color:#2c3e50;text-align:center}.header .header-content .header-title{color:#5b86e5;display:block;font-size:32px;font-weight:700;letter-spacing:.5px;margin-bottom:8px}.header .header-content .header-subtitle{color:#606266;font-size:14px;font-weight:500;opacity:.8}.stats-section{padding:0 20px 30px}.stats-section .stats-card{align-items:center;backdrop-filter:blur(10px);background:hsla(0,0%,100%,.9);border:1px solid rgba(91,134,229,.1);border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,.04);display:flex;justify-content:space-around;padding:20px}.stats-section .stats-card .stat-item{flex:1;text-align:center}.stats-section .stats-card .stat-item .stat-value{color:#5b86e5;display:block;font-size:28px;font-weight:700;margin-bottom:6px}.stats-section .stats-card .stat-item .stat-label{color:#909399;font-size:12px;font-weight:500}.stats-section .stats-card .stat-divider{background:#dcdfe6;height:32px;width:1px}.overview-section{padding:0 20px 30px}.overview-section .section-header{margin-bottom:16px}.overview-section .section-header .section-title{color:#2c3e50;font-size:18px;font-weight:600}.overview-section .overview-card{background:#fff;border:1px solid #ebeef5;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.04);padding:18px}.overview-section .overview-card .overview-item{align-items:center;border-bottom:1px solid #f5f7fa;display:flex;justify-content:space-between;padding:10px 0}.overview-section .overview-card .overview-item:last-child{border-bottom:none}.overview-section .overview-card .overview-item .overview-label{color:#606266;font-size:13px;font-weight:500}.overview-section .overview-card .overview-item .overview-value{color:#2c3e50;font-size:15px;font-weight:700}.categories-section{padding:0 20px 30px}.categories-section .section-header{margin-bottom:16px}.categories-section .section-header .section-title{color:#2c3e50;font-size:18px;font-weight:600}.categories-section .categories-list{background:#fff;border:1px solid #ebeef5;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.04);padding:18px}.categories-section .categories-list .category-item{margin-bottom:14px}.categories-section .categories-list .category-item:last-child{margin-bottom:0}.categories-section .categories-list .category-item .category-info{align-items:center;display:flex;justify-content:space-between;margin-bottom:6px}.categories-section .categories-list .category-item .category-info .category-name{color:#2c3e50;font-size:14px;font-weight:600}.categories-section .categories-list .category-item .category-info .category-count{color:#909399;font-size:12px;font-weight:500}.categories-section .categories-list .category-item .progress-bar{background:#f5f7fa;border-radius:3px;height:6px;overflow:hidden}.categories-section .categories-list .category-item .progress-bar .progress-fill{border-radius:3px;height:100%;transition:width .3s ease}.actions-section{padding:0 20px 30px}.actions-section .action-card{align-items:center;background:hsla(0,0%,100%,.9);border:1px solid #ebeef5;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.04);cursor:pointer;display:flex;gap:10px;justify-content:center;padding:18px;transition:all .3s ease}.actions-section .action-card:active{background:hsla(0,0%,100%,.7);transform:scale(.98)}.actions-section .action-card .action-icon{font-size:20px}.actions-section .action-card .action-text{color:#f56c6c;font-size:14px;font-weight:600}
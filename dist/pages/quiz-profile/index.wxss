.quiz-profile{background:linear-gradient(135deg,#10b981,#059669);min-height:100vh;padding-bottom:40px}.header{padding:40px 20px 30px}.header .header-content{color:#fff;text-align:center}.header .header-content .header-title{display:block;font-size:36px;font-weight:800;letter-spacing:1px;margin-bottom:8px}.header .header-content .header-subtitle{font-size:16px;font-weight:500;opacity:.9}.stats-section{padding:0 20px 30px}.stats-section .stats-card{align-items:center;backdrop-filter:blur(10px);background:hsla(0,0%,100%,.15);border:1px solid hsla(0,0%,100%,.2);border-radius:20px;box-shadow:0 8px 32px rgba(0,0,0,.1);display:flex;justify-content:space-around;padding:24px}.stats-section .stats-card .stat-item{flex:1;text-align:center}.stats-section .stats-card .stat-item .stat-value{color:#fff;display:block;font-size:32px;font-weight:800;margin-bottom:6px}.stats-section .stats-card .stat-item .stat-label{color:hsla(0,0%,100%,.9);font-size:13px;font-weight:500}.stats-section .stats-card .stat-divider{background:hsla(0,0%,100%,.3);height:40px;width:1px}.overview-section{padding:0 20px 30px}.overview-section .section-header{margin-bottom:16px}.overview-section .section-header .section-title{color:#fff;font-size:20px;font-weight:700}.overview-section .overview-card{background:#fff;border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);padding:20px}.overview-section .overview-card .overview-item{align-items:center;border-bottom:1px solid #f3f4f6;display:flex;justify-content:space-between;padding:12px 0}.overview-section .overview-card .overview-item:last-child{border-bottom:none}.overview-section .overview-card .overview-item .overview-label{color:#6b7280;font-size:14px;font-weight:500}.overview-section .overview-card .overview-item .overview-value{color:#1f2937;font-size:16px;font-weight:700}.categories-section{padding:0 20px 30px}.categories-section .section-header{margin-bottom:16px}.categories-section .section-header .section-title{color:#fff;font-size:20px;font-weight:700}.categories-section .categories-list{background:#fff;border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);padding:20px}.categories-section .categories-list .category-item{margin-bottom:16px}.categories-section .categories-list .category-item:last-child{margin-bottom:0}.categories-section .categories-list .category-item .category-info{align-items:center;display:flex;justify-content:space-between;margin-bottom:8px}.categories-section .categories-list .category-item .category-info .category-name{color:#1f2937;font-size:15px;font-weight:600}.categories-section .categories-list .category-item .category-info .category-count{color:#6b7280;font-size:13px;font-weight:500}.categories-section .categories-list .category-item .progress-bar{background:#f3f4f6;border-radius:4px;height:8px;overflow:hidden}.categories-section .categories-list .category-item .progress-bar .progress-fill{border-radius:4px;height:100%;transition:width .3s ease}.actions-section{padding:0 20px 30px}.actions-section .action-card{align-items:center;background:hsla(0,0%,100%,.95);border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);cursor:pointer;display:flex;gap:12px;justify-content:center;padding:20px;transition:all .3s ease}.actions-section .action-card:active{background:hsla(0,0%,100%,.85);transform:scale(.98)}.actions-section .action-card .action-icon{font-size:24px}.actions-section .action-card .action-text{color:#ef4444;font-size:16px;font-weight:600}